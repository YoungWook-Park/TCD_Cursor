<Window x:Class="Tcd.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Tcd.App"
                 xmlns:behavior="http://schemas.microsoft.com/xaml/behaviors"
                 mc:Ignorable="d"
                 Title="TCD Simulator"
                 WindowStyle="None"
                 ResizeMode="NoResize"
                 WindowState="Maximized"
                 d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel}"
                 
                 d:DesignHeight="830" d:DesignWidth="1600" x:Name="uc"
                 Background="{StaticResource WindowBackgroundBrush}">
    <behavior:Interaction.Triggers>
        <behavior:PropertyChangedTrigger Binding="{Binding IsVisible, ElementName=uc}">
            <behavior:InvokeCommandAction Command="{Binding CMD_VisibleChanged}" CommandParameter="{Binding IsVisible, ElementName=uc}"/>
        </behavior:PropertyChangedTrigger>
    </behavior:Interaction.Triggers>
    <Window.Resources>
        <!-- ViewModel 타입에 따른 뷰 매핑 -->
        <DataTemplate DataType="{x:Type local:MainWindowViewModel}">
            <local:MainView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:RecipeViewModel}">
            <local:RecipeView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:ManualViewModel}">
            <local:ManualView DataContext="{Binding}" />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 상단 제어 영역 -->
            <RowDefinition Height="Auto"/>
            <!-- 메인 컨텐츠 영역 -->
            <RowDefinition Height="*"/>
            <!-- 하단 네비게이션 바 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 제어 버튼/상태 표시 -->
        <Grid Margin="8" Background="{StaticResource PanelBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="8,4,0,4">
                <Button Content="Load Stage" Width="110" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Cmd_LoadStageCommand}" />
                <Button Content="Start" Width="90" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Cmd_StartAutoCommand}" />
                <Button Content="Stop" Width="90" Margin="0,0,8,0"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding Cmd_StopCommand}" />
                <Button Content="Clear" Width="90"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Cmd_ClearCommand}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,8,4">
                <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="Status:"/>
                <TextBlock Margin="0,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource HighlightTextBlockStyle}"
                           Text="{Binding Status}"/>
            </StackPanel>
        </Grid>

        <!-- 메인 컨텐츠 (현재 선택된 뷰) -->
        <Border Grid.Row="1" Margin="12,4,12,8" Background="{StaticResource PanelBackgroundBrush}">
            <ContentControl Content="{Binding CurrentContent}" />
        </Border>

        <!-- 하단 네비게이션 바 -->
        <Grid Grid.Row="2" Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Width="100" Margin="4"
                        Content="Main"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Cmd_ShowMainPage}" />
                <Button Width="100" Margin="4"
                        Content="Recipe"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Cmd_ShowRecipePage}" />
                <Button Width="100" Margin="4"
                        Content="Manual"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Cmd_ShowManualPage}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Width="80"
                    Content="Exit"
                    Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding Cmd_ExitCommand}" />
        </Grid>
    </Grid>
</Window>

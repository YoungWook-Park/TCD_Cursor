<Application x:Class="Tcd.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Tcd.App"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             Startup="App_OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 브러시 정의 -->
                <ResourceDictionary Source="Styles/Brushes.xaml" />
                <!-- 컨트롤별 스타일 -->
                <ResourceDictionary Source="Styles/Controls/Window.xaml" />
                <ResourceDictionary Source="Styles/Controls/TextBlock.xaml" />
                <ResourceDictionary Source="Styles/Controls/Button.xaml" />
                <ResourceDictionary Source="Styles/Controls/GroupBox.xaml" />
                <ResourceDictionary Source="Styles/Controls/TextBox.xaml" />
                <ResourceDictionary Source="Styles/Controls/TabControl.xaml" />
                <ResourceDictionary Source="Styles/Controls/DataGrid.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>


<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Dark theme brushes -->
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E1E1E"/>
  <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF2B2B2B"/>
  <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF3A3A3A"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#FF3FA9F5"/>
  <SolidColorBrush x:Key="AccentBrushSoft" Color="#FF2D7BB5"/>
  <SolidColorBrush x:Key="TextBrush" Color="#FFF0F0F0"/>
  <SolidColorBrush x:Key="TextSubtleBrush" Color="#FFB0B0B0"/>
  <SolidColorBrush x:Key="DangerBrush" Color="#FFCC3333"/>
</ResourceDictionary>


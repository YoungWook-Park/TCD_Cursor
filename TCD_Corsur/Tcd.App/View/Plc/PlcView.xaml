<UserControl x:Class="Tcd.App.View.PlcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tcd.App"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="920"
             d:DataContext="{d:DesignInstance Type=local:PlcViewModel}">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Connection -->
      <RowDefinition Height="*"/>     <!-- IO Map -->
      <RowDefinition Height="Auto"/>  <!-- Log -->
    </Grid.RowDefinitions>

    <!-- ══ Row 0: Connection ═══════════════════════════════════════════ -->
    <GroupBox Grid.Row="0" Header="Connection" Margin="0,0,0,6">
      <Grid Margin="8,4,8,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="110"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="60"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <TextBox   Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                   VerticalContentAlignment="Center" Padding="4,2"/>

        <TextBlock Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="8,0,4,0"/>
        <TextBox   Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                   VerticalContentAlignment="Center" Padding="4,2"/>

        <Button Grid.Column="4" Content="Connect"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_Connect}"
                Width="80" Margin="8,0,4,0"/>
        <Button Grid.Column="5" Content="Disconnect"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_Disconnect}"
                Width="85" Margin="0,0,12,0"/>

        <Button Grid.Column="6" Content="▶ Monitor"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_StartMonitor}"
                Width="85" Margin="0,0,4,0"/>
        <Button Grid.Column="7" Content="■ Stop"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_StopMonitor}"
                Width="65"/>

        <!-- Status LEDs -->
        <StackPanel Grid.Column="9" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="8,0,0,0">
          <Ellipse Style="{StaticResource ConnLedStyle}" Margin="0,0,3,0"/>
          <TextBlock Text="Conn" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11" Cursor=""/>
          <Ellipse Style="{StaticResource MonLedStyle}"  Margin="0,0,3,0"/>
          <TextBlock Text="Mon"  VerticalAlignment="Center" FontSize="11"/>
        </StackPanel>
      </Grid>
    </GroupBox>

    <!-- ══ Row 1: IO Map (DI | AI | DO) ═══════════════════════════════ -->
    <Grid Grid.Row="1" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>   <!-- DI -->
        <ColumnDefinition Width="180"/> <!-- AI -->
        <ColumnDefinition Width="160"/> <!-- DO -->
      </Grid.ColumnDefinitions>

      <!-- ── DI Status ─────────────────────────────────────────────── -->
      <GroupBox Grid.Column="0" Header="DI — PLC Input" Margin="0,0,4,0">
        <StackPanel Margin="8,4,8,8">

          <!-- DI 행 공통 DataTemplate 대신 직접 나열 (13개, 간결하게) -->
          <ItemsControl>
            <ItemsControl.Items>
              <!-- 각 행: LED + 심볼 + 값 -->
            </ItemsControl.Items>
          </ItemsControl>

          <!-- B0.* -->
          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_EStop_OK}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B0.0  EStop_OK"        FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_DoorClosed}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B0.1  DoorClosed"      FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_LowStageVac}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B0.4  LowStageVac"     FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_HighStageVac}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B0.5  HighStageVac"    FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_RobotGripVac}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B0.6  RobotGripVac"    FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_UpperChamberVac}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B0.7  UpperChamberVac" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <Separator Margin="0,4,0,4"/>

          <!-- B1.* -->
          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_LowerChamberAtReady}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B1.2  LwrChAtReady"    FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_UpperChamberAtReady}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B1.3  UprChAtReady"    FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_LowerChamberAtBond}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B1.4  LwrChAtBond"     FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_UpperChamberAtBond}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B1.5  UprChAtBond"     FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_MaterialLowStage}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B1.6  MaterialLow"     FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_MaterialHighStage}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B1.7  MaterialHigh"    FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

          <Separator Margin="0,4,0,4"/>

          <!-- B2.* -->
          <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#444"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DI_AtAtmospheric}" Value="True">
                      <Setter Property="Fill" Value="#44DD66"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="B2.0  AtAtmospheric"   FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>

        </StackPanel>
      </GroupBox>

      <!-- ── AI Values ──────────────────────────────────────────────── -->
      <GroupBox Grid.Column="1" Header="AI — Analog Input" Margin="4,0,4,0">
        <StackPanel Margin="8,8,8,8" VerticalAlignment="Center">

          <!-- 챔버 압력 -->
          <Border BorderThickness="0,0,0,1" BorderBrush="#333" Padding="0,0,0,12" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Chamber Pressure" Style="{StaticResource AiLabelStyle}"/>
              <TextBlock Style="{StaticResource AiValueStyle}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:F1} kPa">
                    <Binding Path="ChamberPressure_kPa"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="W0  (raw / 100)" Style="{StaticResource AiLabelStyle}" FontSize="10"/>
            </StackPanel>
          </Border>

          <!-- 진공도 (실시간 갱신 핵심 값) -->
          <Border BorderThickness="1" BorderBrush="#3FA9F5"
                  CornerRadius="4" Padding="0,8" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Chamber Vacuum" Style="{StaticResource AiLabelStyle}"/>
              <TextBlock Style="{StaticResource AiValueStyle}" FontSize="26"
                         Foreground="#44DD66">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:F1} kPa">
                    <Binding Path="ChamberVacuum_kPa"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="W4  (raw / 10)" Style="{StaticResource AiLabelStyle}" FontSize="10"/>
            </StackPanel>
          </Border>

          <!-- 로드셀 -->
          <StackPanel>
            <TextBlock Text="Load Cell" Style="{StaticResource AiLabelStyle}"/>
            <TextBlock Style="{StaticResource AiValueStyle}">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:F1} N">
                  <Binding Path="Loadcell_N"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Text="W2  (raw / 10)" Style="{StaticResource AiLabelStyle}" FontSize="10"/>
          </StackPanel>

        </StackPanel>
      </GroupBox>

      <!-- ── DO Control ─────────────────────────────────────────────── -->
      <GroupBox Grid.Column="2" Header="DO — Output Write" Margin="4,0,0,0">
        <StackPanel Margin="8,4,8,8">

          <TextBlock Text="Toggle = ON / OFF" FontSize="10"
                     Foreground="#AAA" Margin="0,0,0,6"/>

          <Button Content="{Binding DO_VacPump, Converter={x:Null},
                            ConverterParameter='VacPump', StringFormat='VacPump [{0}]'}"
                  Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleVacPump}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="VacPump  "/>
                  <Run Text="{Binding DataContext.DO_VacPump,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleLowStageVac}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="LowStageVac "/>
                  <Run Text="{Binding DataContext.DO_LowStageVac,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleHighStageVac}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="HighStageVac"/>
                  <Run Text="{Binding DataContext.DO_HighStageVac,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleRobotGripVac}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="RobotGripVac"/>
                  <Run Text="{Binding DataContext.DO_RobotGripVac,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleUpperChamberVac}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="UprChVac "/>
                  <Run Text="{Binding DataContext.DO_UpperChamberVac,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleEscEnable}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="ESC Enable "/>
                  <Run Text="{Binding DataContext.DO_EscEnable,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Separator Margin="0,6,0,2"/>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleChamberBond}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="ChamberBond"/>
                  <Run Text="{Binding DataContext.DO_ChamberMoveToBond,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleLamination}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="Lamination "/>
                  <Run Text="{Binding DataContext.DO_LaminationActive,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

          <Button Style="{StaticResource DoToggleStyle}"
                  Command="{Binding Cmd_ToggleVentValve}">
            <Button.ContentTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="VentValve  "/>
                  <Run Text="{Binding DataContext.DO_VentValveOpen,
                       RelativeSource={RelativeSource AncestorType=Button},
                       Mode=OneWay,
                       StringFormat='[ {0} ]'}"/>
                </TextBlock>
              </DataTemplate>
            </Button.ContentTemplate>
          </Button>

        </StackPanel>
      </GroupBox>

    </Grid>

    <!-- ══ Row 2: Status Log ════════════════════════════════════════════ -->
    <GroupBox Grid.Row="2" Header="Status">
      <TextBlock Margin="8,4,8,8"
                 Text="{Binding LogStatus}"
                 FontFamily="Consolas" FontSize="12"
                 Foreground="{StaticResource TextBrush}"
                 TextWrapping="Wrap"/>
    </GroupBox>

  </Grid>
</UserControl>

<UserControl x:Class="Tcd.App.View.Manual_RobotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tcd.App"
             mc:Ignorable="d"
             d:DesignHeight="850" d:DesignWidth="1800"
             d:DataContext="{d:DesignInstance Type=local:Manual_RobotViewModel}">
  <UserControl.Resources>
    <!-- Running indicator: Yellow=running -->
    <Style x:Key="RunLedStyle" TargetType="Ellipse">
      <Setter Property="Width"  Value="12"/>
      <Setter Property="Height" Value="12"/>
      <Setter Property="Fill"   Value="#555"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsRunning}" Value="True">
          <Setter Property="Fill" Value="#FFDD44"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <!-- Error indicator: Red=error -->
    <Style x:Key="ErrLedStyle" TargetType="Ellipse">
      <Setter Property="Width"  Value="12"/>
      <Setter Property="Height" Value="12"/>
      <Setter Property="Fill"   Value="#555"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsError}" Value="True">
          <Setter Property="Fill" Value="#FF4444"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ── Move Buttons ───────────────────────────────────────────────── -->
    <GroupBox Grid.Row="0" Header="Teach Positions" Margin="0,0,0,6">
      <StackPanel Margin="8,4,8,8">

        <!-- Safe positions row -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="Safe:" Width="50" VerticalAlignment="Center" FontSize="11" Foreground="#AAA"/>
          <Button Content="Home"  Width="80" Margin="0,0,6,0"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveHome}"/>
          <Button Content="Ready" Width="80" Margin="0,0,6,0"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveReady}"/>
          <Button Content="STOP"  Width="80" Background="#AA2222" Foreground="White"
                  FontWeight="Bold"
                  Command="{Binding Cmd_Stop}"/>
        </StackPanel>

        <Separator Margin="0,2,0,6"/>

        <!-- S1 (CGO / Upper Film) -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="S1:" Width="50" VerticalAlignment="Center" FontSize="11" Foreground="#AAA"/>
          <Button Content="S1 Wait" Width="90" Margin="0,0,6,0"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveS1Wait}"/>
          <Button Content="S1 Pick" Width="90"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveS1Pick}"/>
        </StackPanel>

        <!-- S2 / LowStage (OCA / Lower Film) -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="S2:" Width="50" VerticalAlignment="Center" FontSize="11" Foreground="#AAA"/>
          <Button Content="S2 Wait" Width="90" Margin="0,0,6,0"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveS2Wait}"/>
          <Button Content="S2 Pick" Width="90"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveS2Pick}"/>
        </StackPanel>

        <!-- Upper Chamber -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="Upper Ch:" Width="50" VerticalAlignment="Center" FontSize="11" Foreground="#AAA"/>
          <Button Content="UC Wait" Width="90" Margin="0,0,6,0"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveUcWait}"/>
          <Button Content="UC Pick" Width="90"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveUcPick}"/>
        </StackPanel>

        <!-- Lower Chamber -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="Lower Ch:" Width="50" VerticalAlignment="Center" FontSize="11" Foreground="#AAA"/>
          <Button Content="LC Wait" Width="90" Margin="0,0,6,0"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveLcWait}"/>
          <Button Content="LC Pick" Width="90"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MoveLcPick}"/>
        </StackPanel>

        <!-- Peel -->
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Peel:" Width="50" VerticalAlignment="Center" FontSize="11" Foreground="#AAA"/>
          <Button Content="Peel" Width="90"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding Cmd_MovePeel}"/>
        </StackPanel>

      </StackPanel>
    </GroupBox>

    <!-- ── Status Log ──────────────────────────────────────────────────── -->
    <GroupBox Grid.Row="1" Header="Status">
      <Grid Margin="8,4,8,8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding LogStatus}"
                   FontFamily="Consolas" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
          <TextBlock Text="Position: " FontSize="11" Foreground="#AAA"/>
          <TextBlock Text="{Binding CurrentPosition}" FontSize="11"/>
          <TextBlock Text="  Home: " FontSize="11" Foreground="#AAA" Margin="12,0,0,0"/>
          <TextBlock Text="{Binding IsHome}" FontSize="11"/>
        </StackPanel>
      </Grid>
    </GroupBox>

  </Grid>
</UserControl>

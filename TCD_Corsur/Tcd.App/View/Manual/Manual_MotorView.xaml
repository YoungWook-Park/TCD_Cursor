<UserControl x:Class="Tcd.App.Manual.Manual_MotorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:local="clr-namespace:Tcd.App"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=local:Manual_MotorViewModel}">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Teach / move controls -->
    <GroupBox Header="Axes (Teach / Move)">
      <Grid Margin="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="70"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,6" Text="U"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,10,6" Text="{Binding U, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="0" Grid.Column="2" Margin="0,0,8,6" Content="Move"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_MoveU}" />
        <Button Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" Content="Teach"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_TeachU}" />
            <Button Grid.Row="0" Grid.Column="4" Margin="0,0,0,6" Content="Stop"
          Style="{StaticResource PrimaryButtonStyle}"
          Command="{Binding Cmd_StopU}" />
          
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,6" Text="V"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,10,6" Text="{Binding V, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="1" Grid.Column="2" Margin="0,0,8,6" Content="Move"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_MoveV}" />
        <Button Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" Content="Teach"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_TeachV}" />
                <Button Grid.Row="1" Grid.Column="4" Margin="0,0,0,6" Content="Stop"
  Style="{StaticResource PrimaryButtonStyle}"
  Command="{Binding Cmd_StopV}" />
          
                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,6" Text="W"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,10,6" Text="{Binding W, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="2" Grid.Column="2" Margin="0,0,8,6" Content="Move"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_MoveW}" />
        <Button Grid.Row="2" Grid.Column="3" Margin="0,0,0,6" Content="Teach"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_TeachW}" />
                <Button Grid.Row="2" Grid.Column="4" Margin="0,0,0,6" Content="Stop"
  Style="{StaticResource PrimaryButtonStyle}"
  Command="{Binding Cmd_StopW}" />
          
                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,6" Text="Z Load"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,10,6" Text="{Binding ZLoad, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="3" Grid.Column="2" Margin="0,0,8,6" Content="Move"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_MoveZLoad}" />
        <Button Grid.Row="3" Grid.Column="3" Margin="0,0,0,6" Content="Teach"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_TeachZLoad}" />
                <Button Grid.Row="3" Grid.Column="4" Margin="0,0,0,6" Content="Stop"
  Style="{StaticResource PrimaryButtonStyle}"
  Command="{Binding Cmd_StopZLoad}" />
          
                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,10,0" Text="Z Bond"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,10,0" Text="{Binding ZBond, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="4" Grid.Column="2" Margin="0,0,8,0" Content="Move"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_MoveZBond}" />
        <Button Grid.Row="4" Grid.Column="3" Content="Teach"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding Cmd_TeachZBond}" />
                <Button Grid.Row="4" Grid.Column="4" Content="Stop"
  Style="{StaticResource PrimaryButtonStyle}"
  Command="{Binding Cmd_StopZBond}" />
          
                <!-- Jog controls -->
        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,10,0" Text="Jog"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
          <ComboBox Width="80" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxis}" />
          <TextBox Width="80" Margin="8,0,0,0" Text="{Binding JogSpeed, UpdateSourceTrigger=PropertyChanged}" />
          <Button Content="+Jog" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}">
            <i:Interaction.Triggers>
              <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                <i:InvokeCommandAction Command="{Binding Cmd_JogPlusDown}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                <i:InvokeCommandAction Command="{Binding Cmd_JogPlusUp}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="MouseLeave">
                <i:InvokeCommandAction Command="{Binding Cmd_JogPlusUp}" />
              </i:EventTrigger>
            </i:Interaction.Triggers>
          </Button>
          <Button Content="-Jog" Margin="4,0,0,0" Style="{StaticResource PrimaryButtonStyle}">
            <i:Interaction.Triggers>
              <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                <i:InvokeCommandAction Command="{Binding Cmd_JogMinusDown}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                <i:InvokeCommandAction Command="{Binding Cmd_JogMinusUp}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="MouseLeave">
                <i:InvokeCommandAction Command="{Binding Cmd_JogMinusUp}" />
              </i:EventTrigger>
            </i:Interaction.Triggers>
          </Button>
        </StackPanel>
      </Grid>
    </GroupBox>

    <!-- Motor status grid (WPF DataGrid) -->
    <GroupBox Grid.Row="1" Header="Motor Status">
      <Grid Margin="10">
        <DataGrid ItemsSource="{Binding AxisStatuses}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeight="28">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Axis" Binding="{Binding AxisName}" Width="*" />
            <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="*" />
            <DataGridTextColumn Header="Is Home" Binding="{Binding IsHome}" Width="*" />
            <DataGridTextColumn Header="Is Moving" Binding="{Binding IsMoving}" Width="*" />
            <DataGridTextColumn Header="Fault" Binding="{Binding IsFault}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </GroupBox>

    <!-- Stop button -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Content="STOP ALL" Width="120"
              Style="{StaticResource DangerButtonStyle}"
              Command="{Binding Cmd_StopAllMotors}" />
    </StackPanel>
  </Grid>
</UserControl>


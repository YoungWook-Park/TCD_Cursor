<UserControl x:Class="Tcd.App.View.Manual_MotorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:Tcd.App"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=local:Manual_MotorViewModel}">
  <UserControl.Resources>
    <!-- 셀 상태 색상 (배경 틴트 + 텍스트) -->
    <Color x:Key="CellGreenBg">#2522AA44</Color>
    <Color x:Key="CellGreenFg">#FF44CC66</Color>
    <Color x:Key="CellOrangeBg">#33CC8800</Color>
    <Color x:Key="CellOrangeFg">#FFCC9900</Color>
    <Color x:Key="CellRedBg">#33CC2222</Color>
    <Color x:Key="CellRedFg">#FFEE4444</Color>
    <Color x:Key="CellOffFg">#FF555555</Color>
    <SolidColorBrush x:Key="CellGreenBgBrush" Color="{StaticResource CellGreenBg}"/>
    <SolidColorBrush x:Key="CellGreenFgBrush" Color="{StaticResource CellGreenFg}"/>
    <SolidColorBrush x:Key="CellOrangeBgBrush" Color="{StaticResource CellOrangeBg}"/>
    <SolidColorBrush x:Key="CellOrangeFgBrush" Color="{StaticResource CellOrangeFg}"/>
    <SolidColorBrush x:Key="CellRedBgBrush" Color="{StaticResource CellRedBg}"/>
    <SolidColorBrush x:Key="CellRedFgBrush" Color="{StaticResource CellRedFg}"/>
    <SolidColorBrush x:Key="CellOffFgBrush" Color="{StaticResource CellOffFg}"/>
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Teach / move controls -->
    <GroupBox Header="Axes (Teach / Move)">
      <Grid Margin="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="70"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,6" Text="U"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,10,6" Text="{Binding U, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="0" Grid.Column="2" Margin="0,0,6,6" Content="Move" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_MoveU}" />
        <Button Grid.Row="0" Grid.Column="3" Margin="0,0,6,6" Content="Teach" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_TeachU}" />
        <Button Grid.Row="0" Grid.Column="4" Margin="0,0,6,6" Content="Stop" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_StopU}" />
        <Button Grid.Row="0" Grid.Column="5" Margin="0,0,6,6" Content="Servo On" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOnU}" />
        <Button Grid.Row="0" Grid.Column="6" Margin="0,0,6,6" Content="Servo Off" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOffU}" />
        <Button Grid.Row="0" Grid.Column="7" Margin="0,0,0,6" Content="Home" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_HomeU}" />
          
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,6" Text="V"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,10,6" Text="{Binding V, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="1" Grid.Column="2" Margin="0,0,6,6" Content="Move" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_MoveV}" />
        <Button Grid.Row="1" Grid.Column="3" Margin="0,0,6,6" Content="Teach" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_TeachV}" />
        <Button Grid.Row="1" Grid.Column="4" Margin="0,0,6,6" Content="Stop" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_StopV}" />
        <Button Grid.Row="1" Grid.Column="5" Margin="0,0,6,6" Content="Servo On" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOnV}" />
        <Button Grid.Row="1" Grid.Column="6" Margin="0,0,6,6" Content="Servo Off" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOffV}" />
        <Button Grid.Row="1" Grid.Column="7" Margin="0,0,0,6" Content="Home" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_HomeV}" />
          
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,6" Text="W"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,10,6" Text="{Binding W, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="2" Grid.Column="2" Margin="0,0,6,6" Content="Move" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_MoveW}" />
        <Button Grid.Row="2" Grid.Column="3" Margin="0,0,6,6" Content="Teach" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_TeachW}" />
        <Button Grid.Row="2" Grid.Column="4" Margin="0,0,6,6" Content="Stop" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_StopW}" />
        <Button Grid.Row="2" Grid.Column="5" Margin="0,0,6,6" Content="Servo On" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOnW}" />
        <Button Grid.Row="2" Grid.Column="6" Margin="0,0,6,6" Content="Servo Off" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOffW}" />
        <Button Grid.Row="2" Grid.Column="7" Margin="0,0,0,6" Content="Home" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_HomeW}" />
          
        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,6" Text="Z Load"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,10,6" Text="{Binding ZLoad, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="3" Grid.Column="2" Margin="0,0,6,6" Content="Move" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_MoveZLoad}" />
        <Button Grid.Row="3" Grid.Column="3" Margin="0,0,6,6" Content="Teach" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_TeachZLoad}" />
        <Button Grid.Row="3" Grid.Column="4" Margin="0,0,6,6" Content="Stop" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_StopZLoad}" />
        <Button Grid.Row="3" Grid.Column="5" Margin="0,0,6,6" Content="Servo On" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOnZLoad}" />
        <Button Grid.Row="3" Grid.Column="6" Margin="0,0,6,6" Content="Servo Off" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOffZLoad}" />
        <Button Grid.Row="3" Grid.Column="7" Margin="0,0,0,6" Content="Home" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_HomeZLoad}" />
          
        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,10,0" Text="Z Bond"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,10,0" Text="{Binding ZBond, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Row="4" Grid.Column="2" Margin="0,0,6,0" Content="Move" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_MoveZBond}" />
        <Button Grid.Row="4" Grid.Column="3" Margin="0,0,6,0" Content="Teach" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_TeachZBond}" />
        <Button Grid.Row="4" Grid.Column="4" Margin="0,0,6,0" Content="Stop" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_StopZBond}" />
        <Button Grid.Row="4" Grid.Column="5" Margin="0,0,6,0" Content="Servo On" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOnZBond}" />
        <Button Grid.Row="4" Grid.Column="6" Margin="0,0,6,0" Content="Servo Off" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_ServoOffZBond}" />
        <Button Grid.Row="4" Grid.Column="7" Margin="0,0,0,0" Content="Home" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding Cmd_HomeZBond}" />
          
        <!-- Jog controls -->
        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,10,0" Text="Jog"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="7" Orientation="Horizontal" Margin="0,8,0,0">
          <ComboBox Width="80" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxis}" />
          <TextBox Width="80" Margin="8,0,0,0" Text="{Binding JogSpeed, UpdateSourceTrigger=PropertyChanged}" />
          <Button Content="+Jog" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}">
            <i:Interaction.Triggers>
              <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                <i:InvokeCommandAction Command="{Binding Cmd_JogPlusDown}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                <i:InvokeCommandAction Command="{Binding Cmd_JogPlusUp}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="MouseLeave">
                <i:InvokeCommandAction Command="{Binding Cmd_JogPlusUp}" />
              </i:EventTrigger>
            </i:Interaction.Triggers>
          </Button>
          <Button Content="-Jog" Margin="4,0,0,0" Style="{StaticResource PrimaryButtonStyle}">
            <i:Interaction.Triggers>
              <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                <i:InvokeCommandAction Command="{Binding Cmd_JogMinusDown}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                <i:InvokeCommandAction Command="{Binding Cmd_JogMinusUp}" />
              </i:EventTrigger>
              <i:EventTrigger EventName="MouseLeave">
                <i:InvokeCommandAction Command="{Binding Cmd_JogMinusUp}" />
              </i:EventTrigger>
            </i:Interaction.Triggers>
          </Button>
        </StackPanel>
      </Grid>
    </GroupBox>

    <!-- Motor status grid: 개별 셀별 색상 표시 -->
    <GroupBox Grid.Row="1" Header="Motor Status">
      <DataGrid ItemsSource="{Binding AxisStatuses}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                RowHeight="26"
                Margin="4">
        <DataGrid.Columns>

          <!-- Axis 이름 -->
          <DataGridTextColumn Header="Axis" Binding="{Binding AxisName}" Width="70"/>

          <!-- Position -->
          <DataGridTextColumn Header="Position" Binding="{Binding Position, StringFormat=N3}" Width="90"/>

          <!-- Servo On: 초록=ON, 회색=OFF -->
          <DataGridTemplateColumn Header="Servo" Width="60">
            <DataGridTemplateColumn.CellStyle>
              <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsServoOn}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CellGreenBgBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="OFF"/>
                      <Setter Property="Foreground" Value="{StaticResource CellOffFgBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsServoOn}" Value="True">
                          <Setter Property="Text" Value="ON"/>
                          <Setter Property="Foreground" Value="{StaticResource CellGreenFgBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Home: 초록=HOME, 회색=- -->
          <DataGridTemplateColumn Header="Home" Width="60">
            <DataGridTemplateColumn.CellStyle>
              <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsHome}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CellGreenBgBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="—"/>
                      <Setter Property="Foreground" Value="{StaticResource CellOffFgBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHome}" Value="True">
                          <Setter Property="Text" Value="HOME"/>
                          <Setter Property="Foreground" Value="{StaticResource CellGreenFgBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Moving: 주황=MOVING, 회색=- -->
          <DataGridTemplateColumn Header="Moving" Width="70">
            <DataGridTemplateColumn.CellStyle>
              <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsMoving}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CellOrangeBgBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="—"/>
                      <Setter Property="Foreground" Value="{StaticResource CellOffFgBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMoving}" Value="True">
                          <Setter Property="Text" Value="MOVING"/>
                          <Setter Property="Foreground" Value="{StaticResource CellOrangeFgBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Fault: 빨강=FAULT, 회색=- -->
          <DataGridTemplateColumn Header="Fault" Width="60">
            <DataGridTemplateColumn.CellStyle>
              <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFault}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CellRedBgBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="—"/>
                      <Setter Property="Foreground" Value="{StaticResource CellOffFgBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFault}" Value="True">
                          <Setter Property="Text" Value="FAULT"/>
                          <Setter Property="Foreground" Value="{StaticResource CellRedFgBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- +Limit: 빨강=+LMT, 회색=- -->
          <DataGridTemplateColumn Header="+Limit" Width="60">
            <DataGridTemplateColumn.CellStyle>
              <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLimitPos}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CellRedBgBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="—"/>
                      <Setter Property="Foreground" Value="{StaticResource CellOffFgBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLimitPos}" Value="True">
                          <Setter Property="Text" Value="+LMT"/>
                          <Setter Property="Foreground" Value="{StaticResource CellRedFgBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- -Limit: 빨강=-LMT, 회색=- -->
          <DataGridTemplateColumn Header="-Limit" Width="60">
            <DataGridTemplateColumn.CellStyle>
              <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLimitNeg}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CellRedBgBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="—"/>
                      <Setter Property="Foreground" Value="{StaticResource CellOffFgBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLimitNeg}" Value="True">
                          <Setter Property="Text" Value="-LMT"/>
                          <Setter Property="Foreground" Value="{StaticResource CellRedFgBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

        </DataGrid.Columns>
      </DataGrid>
    </GroupBox>

    <!-- Stop button -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Content="STOP ALL" Width="120"
              Style="{StaticResource DangerButtonStyle}"
              Command="{Binding Cmd_StopAllMotors}" />
    </StackPanel>
  </Grid>
</UserControl>


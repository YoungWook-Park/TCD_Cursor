<UserControl x:Class="Tcd.App.View.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tcd.App"
             mc:Ignorable="d"
             d:DesignHeight="850" d:DesignWidth="1800"
             d:DataContext="{d:DesignInstance Type=local:RecipeViewModel}">
    <Grid Margin="12" Background="{StaticResource PanelBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 좌측: 레시피 목록 -->
        <GroupBox Header="Recipes">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Margin="8,8,8,4" FontSize="11"
                           Text="{Binding RecipesDirectory}"/>
                <ListBox Margin="8"
                         ItemsSource="{Binding RecipeNames}"
                         SelectedItem="{Binding SelectedRecipeName}"
                         Background="{StaticResource PanelBackgroundBrush}"/>
            </DockPanel>
        </GroupBox>

        <!-- 우측: 편집 에디터 (TabControl) -->
        <GroupBox Grid.Column="2" Header="Editor">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 레시피 이름 (탭 공통) -->
                <Grid Margin="10,10,10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Name" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- 탭: Motor / Robot -->
                <TabControl Grid.Row="1" Margin="8,4,8,8">

                    <!-- ── Motor 탭 ───────────────────────────────────────── -->
                    <TabItem Header="Motor">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Margin="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 축 티칭 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,10,4" Text="U  (mm)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,4,0,4" Text="{Binding U, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,10,4" Text="V  (mm)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,4,0,4" Text="{Binding V, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,10,4" Text="W  (mm)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,4,0,4" Text="{Binding W, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,4,10,4" Text="Z Load  (mm)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,4,0,4" Text="{Binding ZLoad, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,4,10,4" Text="Z Bond  (mm)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="4" Grid.Column="1" Margin="0,4,0,4" Text="{Binding ZBond, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- 구분선 -->
                                <Separator Grid.Row="5" Grid.ColumnSpan="3" Margin="0,4"/>

                                <!-- 모션 파라미터 -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,4,10,4" Text="Velocity  (mm/s)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="6" Grid.Column="1" Margin="0,4,0,4" Text="{Binding MotionVelocity, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,4,10,4" Text="Acc  (mm/s²)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="7" Grid.Column="1" Margin="0,4,0,4" Text="{Binding MotionAcc, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,4,10,4" Text="Dec  (mm/s²)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="8" Grid.Column="1" Margin="0,4,0,4" Text="{Binding MotionDec, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,4,10,4" Text="Jerk  (mm/s³)" VerticalAlignment="Center"/>
                                <TextBox   Grid.Row="9" Grid.Column="1" Margin="0,4,0,4" Text="{Binding MotionJerk, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ── Robot 탭 ───────────────────────────────────────── -->
                    <TabItem Header="Robot">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Margin="4">
                            <StackPanel>
                                <TextBlock Margin="0,4,0,10" FontSize="11"
                                           Foreground="{StaticResource TextSubtleBrush}"
                                           Text="포지션별 이동 속도 (1 – 100 %). Save 후 반영."/>

                                <ItemsControl ItemsSource="{Binding RobotVelocityRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding PositionName}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox   Grid.Column="1"
                                                           Text="{Binding Velocity, UpdateSourceTrigger=PropertyChanged}"
                                                           TextAlignment="Right"/>
                                                <TextBlock Grid.Column="2"
                                                           Text=" %"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Grid>
        </GroupBox>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="110" Margin="0,0,8,0" Content="Reload"
                    Command="{Binding Cmd_Reload}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="110" Margin="0,0,8,0" Content="New"
                    Command="{Binding Cmd_New}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="110" Margin="0,0,8,0" Content="Save"
                    Command="{Binding Cmd_Save}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="110" Margin="0,0,8,0" Content="Save As..."
                    Command="{Binding Cmd_SaveAs}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                       Text="{Binding Status}"
                       Style="{StaticResource HighlightTextBlockStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="Tcd.App.View.Equipment.EquipmentDiagramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tcd.App.View.Equipment"
             xmlns:vm="clr-namespace:Tcd.App"
             mc:Ignorable="d"
             d:DesignHeight="280" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">
    <UserControl.Resources>
        <Style x:Key="StageRectStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="RadiusX" Value="4"/>
            <Setter Property="RadiusY" Value="4"/>
            <Setter Property="Stroke" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Stage1HasMaterial}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stage1HasMaterial}" Value="False">
                    <Setter Property="Fill" Value="{StaticResource PanelBackgroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Stage2RectStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="RadiusX" Value="4"/>
            <Setter Property="RadiusY" Value="4"/>
            <Setter Property="Stroke" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Stage2HasMaterial}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Stage2HasMaterial}" Value="False">
                    <Setter Property="Fill" Value="{StaticResource PanelBackgroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="UpperChamberRectStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="RadiusX" Value="4"/>
            <Setter Property="RadiusY" Value="4"/>
            <Setter Property="Stroke" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UpperChamberHasMaterial}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UpperChamberHasMaterial}" Value="False">
                    <Setter Property="Fill" Value="{StaticResource PanelBackgroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LowerChamberRectStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="RadiusX" Value="4"/>
            <Setter Property="RadiusY" Value="4"/>
            <Setter Property="Stroke" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding LowerChamberHasMaterial}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LowerChamberHasMaterial}" Value="False">
                    <Setter Property="Fill" Value="{StaticResource PanelBackgroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Canvas Width="400" Height="280" Background="Transparent">
        <!-- Stage1 -->
        <Rectangle Canvas.Left="20" Canvas.Top="120" Style="{StaticResource StageRectStyle}"/>
        <TextBlock Canvas.Left="35" Canvas.Top="132" Text="S1" Foreground="{StaticResource TextBrush}" FontSize="10"/>

        <!-- Stage2 -->
        <Rectangle Canvas.Left="20" Canvas.Top="180" Style="{StaticResource Stage2RectStyle}"/>
        <TextBlock Canvas.Left="35" Canvas.Top="192" Text="S2" Foreground="{StaticResource TextBrush}" FontSize="10"/>

        <!-- Upper Chamber -->
        <Rectangle Canvas.Left="110" Canvas.Top="40" Style="{StaticResource UpperChamberRectStyle}"/>
        <TextBlock Canvas.Left="145" Canvas.Top="52" Text="Upper" Foreground="{StaticResource TextBrush}" FontSize="9"/>

        <!-- Lower Chamber -->
        <Rectangle Canvas.Left="110" Canvas.Top="220" Style="{StaticResource LowerChamberRectStyle}"/>
        <TextBlock Canvas.Left="142" Canvas.Top="232" Text="Lower" Foreground="{StaticResource TextBrush}" FontSize="9"/>

        <!-- Z axis track -->
        <Rectangle Canvas.Left="230" Canvas.Top="230" Width="24" Height="120"
                   Fill="{StaticResource PanelBackgroundBrush}"
                   Stroke="{StaticResource PanelBorderBrush}" StrokeThickness="1"/>
        <Rectangle x:Name="ZBarThumb" Canvas.Left="232" Canvas.Top="250" Width="20" Height="80"
                   Fill="{StaticResource AccentBrush}" RadiusX="2" RadiusY="2"/>

        <!-- Robot -->
        <Ellipse x:Name="RobotEllipse" Width="36" Height="36" Canvas.Left="302" Canvas.Top="2"
                 Fill="{StaticResource AccentBrushSoft}" Stroke="{StaticResource AccentBrush}" StrokeThickness="2"/>

        <!-- Labels -->
        <TextBlock Canvas.Left="228" Canvas.Top="208" Text="Z" Foreground="{StaticResource TextSubtleBrush}" FontSize="10"/>
    </Canvas>
</UserControl>

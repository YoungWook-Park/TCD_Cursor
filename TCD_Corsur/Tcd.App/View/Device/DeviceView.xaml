<UserControl x:Class="Tcd.App.View.DeviceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tcd.App"
             xmlns:s="clr-namespace:Tcd.App.View"
             mc:Ignorable="d"
             d:DesignHeight="850" d:DesignWidth="1800"
             d:DataContext="{d:DesignInstance Type=local:DeviceViewModel}">

  <Grid Margin="12" Background="{StaticResource PanelBackgroundBrush}">
    <TabControl>
      <TabItem Header="SPiiPlus" Height="30" Width="100">
        <s:Device_SpiiPlusView DataContext="{Binding SpiiPlus}"/>
      </TabItem>
      <TabItem Header="Robot" Height="30" Width="100">
        <s:Device_RobotView DataContext="{Binding Robot}"/>
      </TabItem>
      <TabItem Header="PLC" Height="30" Width="100">
        <s:Device_PlcView DataContext="{Binding Plc}"/>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
